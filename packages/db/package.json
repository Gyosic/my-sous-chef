{
  "name": "@repo/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./types/*": "./src/types/*.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "postdb:generate": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/seed/index.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.4.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  }
}
